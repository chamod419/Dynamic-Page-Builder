---

---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Dynamic Page Builder</title>

    <style is:global>
      :root {
        --bg: #1e1e1e;
        --panel: #252526;
        --panel-2: #2d2d30;
        --panel-3: #333333;
        --panel-4: #1b1b1c;
        --border: #3c3c3c;
        --text: #cccccc;
        --muted: #8b8b8b;
        --accent: #0e639c;
        --accent-2: #1177bb;
        --success: #4ec9b0;
        --danger: #f48771;
        --active: #37373d;
        --active-border: #007acc;
        --hover: #2a2d2e;
        --shadow: 0 10px 30px rgba(0, 0, 0, 0.18);

        --folder: #dcb67a;
        --html: #e44d26;
        --css: #42a5f5;
        --js: #f7df1e;
        --react: #61dafb;
        --vue: #42b883;
        --json: #f2c94c;
        --md: #9cdcfe;
        --astro: #ff5d01;
        --text-file: #c5c5c5;
      }

      * {
        box-sizing: border-box;
      }

      html,
      body {
        height: 100%;
      }

      body {
        margin: 0;
        font-family:
          Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont,
          "Segoe UI", Arial, sans-serif;
        background: var(--bg);
        color: var(--text);
        overflow: hidden;
      }

      button,
      input,
      textarea {
        font: inherit;
      }

      button {
        appearance: none;
        -webkit-appearance: none;
      }

      .topbar {
        height: 48px;
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 0 16px;
        border-bottom: 1px solid var(--border);
        background: #181818;
        font-weight: 700;
        font-size: 14px;
      }

      .topbar-sub {
        font-size: 12px;
        color: var(--muted);
        font-weight: 500;
      }

      .app-shell {
        display: grid;
        grid-template-columns: 360px minmax(0, 1fr) minmax(0, 1fr);
        height: calc(100vh - 48px);
        min-height: 0;
      }

      .panel {
        min-width: 0;
        min-height: 0;
        border-right: 1px solid var(--border);
        background: var(--panel);
        display: flex;
        flex-direction: column;
      }

      .panel:last-child {
        border-right: none;
      }

      .panel-head {
        min-height: 44px;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 10px;
        padding: 0 12px;
        border-bottom: 1px solid var(--border);
        background: #181818;
      }

      .panel-title {
        font-size: 11px;
        text-transform: uppercase;
        letter-spacing: 0.08em;
        color: var(--muted);
        font-weight: 800;
      }

      .workspace-scroll {
        min-height: 0;
        overflow: auto;
        padding: 8px 8px 12px;
      }

      .workspace-scroll::-webkit-scrollbar,
      .tree-root::-webkit-scrollbar {
        width: 10px;
      }

      .workspace-scroll::-webkit-scrollbar-track,
      .tree-root::-webkit-scrollbar-track {
        background: #1f1f1f;
      }

      .workspace-scroll::-webkit-scrollbar-thumb,
      .tree-root::-webkit-scrollbar-thumb {
        background: #555;
        border-radius: 999px;
        border: 2px solid #1f1f1f;
      }

      .section-card {
        margin: 0 0 10px;
        border: 1px solid #333333;
        border-radius: 9px;
        overflow: hidden;
        background: #1f1f1f;
        box-shadow: none;
      }

      .section-head {
        min-height: 36px;
        display: grid;
        grid-template-columns: minmax(0, 1fr) auto;
        align-items: center;
        gap: 8px;
        padding: 0 8px 0 10px;
        border-bottom: 1px solid #333333;
        background: #181818;
      }

      .section-title {
        min-width: 0;
        font-size: 11px;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        color: #9da3ad;
        font-weight: 800;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
      }

      .section-body {
        padding: 10px;
      }

      /* Professional VS Code-like action toolbar */
      .toolbar {
        display: inline-flex !important;
        align-items: center !important;
        justify-content: flex-end !important;
        gap: 2px !important;
        flex-wrap: nowrap !important;
        min-width: max-content !important;
      }

      .icon-btn {
        position: relative !important;
        width: 30px !important;
        min-width: 30px !important;
        height: 30px !important;
        display: inline-flex !important;
        align-items: center !important;
        justify-content: center !important;
        gap: 0 !important;
        padding: 0 !important;
        border: 1px solid transparent !important;
        border-radius: 6px !important;
        background: transparent !important;
        color: #c5c5c5 !important;
        cursor: pointer !important;
        box-shadow: none !important;
        transition:
          background 0.12s ease,
          border-color 0.12s ease,
          color 0.12s ease,
          transform 0.12s ease !important;
      }

      .icon-btn:hover {
        background: #2a2d2e !important;
        border-color: #3a3d41 !important;
        color: #ffffff !important;
      }

      .icon-btn:active {
        transform: translateY(1px) !important;
      }

      .icon-btn:disabled {
        opacity: 0.38 !important;
        cursor: not-allowed !important;
        transform: none !important;
      }

      .icon-btn svg {
        width: 15px !important;
        height: 15px !important;
        flex: 0 0 15px !important;
        stroke: currentColor !important;
        stroke-width: 2 !important;
        stroke-linecap: round !important;
        stroke-linejoin: round !important;
        fill: none !important;
      }

      .icon-btn .btn-label {
        position: absolute !important;
        width: 1px !important;
        height: 1px !important;
        padding: 0 !important;
        margin: -1px !important;
        overflow: hidden !important;
        clip: rect(0, 0, 0, 0) !important;
        white-space: nowrap !important;
        border: 0 !important;
      }

      .icon-btn.action-create {
        color: #c5c5c5 !important;
      }

      .icon-btn.action-create:hover {
        color: #89d185 !important;
      }

      .icon-btn.action-rename:hover {
        color: #dcdcaa !important;
      }

      .icon-btn.action-delete:hover {
        color: #f48771 !important;
      }

      .icon-btn.action-refresh:hover {
        color: #75beff !important;
      }

      .project-list,
      .tree-root {
        display: flex;
        flex-direction: column;
        gap: 2px;
      }

      .project-item {
        width: 100%;
        border: 1px solid transparent;
        border-radius: 7px;
        background: transparent !important;
        color: var(--text) !important;
        text-align: left;
        padding: 9px 10px;
        cursor: pointer;
        transition:
          background 0.15s ease,
          border-color 0.15s ease;
      }

      .project-item:hover {
        background: var(--hover) !important;
        border-color: transparent;
      }

      .project-item.active {
        background: var(--active) !important;
        border-color: var(--active-border);
      }

      .project-main-row {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 10px;
      }

      .project-name-wrap {
        min-width: 0;
        display: flex;
        align-items: center;
        gap: 8px;
      }

      .project-name {
        display: block;
        font-size: 13px;
        font-weight: 700;
        color: #dcdcdc;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
      }

      .project-meta {
        display: block;
        margin-top: 4px;
        padding-left: 26px;
        font-size: 11px;
        color: var(--muted);
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
      }

      .type-pill {
        flex: 0 0 auto;
        padding: 3px 8px;
        border-radius: 999px;
        font-size: 10px;
        font-weight: 800;
        letter-spacing: 0.03em;
        border: 1px solid rgba(255, 255, 255, 0.08);
        background: #2c2c2f;
        color: #d4d4d4;
      }

      .type-pill.react {
        background: rgba(97, 218, 251, 0.12);
        color: #88e6ff;
        border-color: rgba(97, 218, 251, 0.25);
      }

      .type-pill.vue {
        background: rgba(65, 184, 131, 0.12);
        color: #80d8ae;
        border-color: rgba(65, 184, 131, 0.25);
      }

      .type-pill.html {
        background: rgba(227, 79, 38, 0.12);
        color: #ffab91;
        border-color: rgba(227, 79, 38, 0.25);
      }

      .explorer-context {
        margin-bottom: 10px;
        padding: 12px;
        border: 1px solid var(--border);
        border-radius: 10px;
        background: #202020;
      }

      .explorer-context strong {
        display: block;
        font-size: 12px;
        margin-bottom: 6px;
        color: #f1f1f1;
      }

      .explorer-context .muted {
        font-size: 12px;
        line-height: 1.5;
      }

      .tree-root {
        max-width: 100%;
        overflow-x: auto;
      }

      .tree-node {
        min-width: 0;
      }

      .tree-children {
        margin-left: 0;
        padding-left: 0;
        border-left: none;
      }

      .tree-row {
        width: 100%;
        min-height: 24px;
        border: 1px solid transparent;
        border-radius: 4px;
        background: transparent !important;
        color: var(--text) !important;
        display: flex;
        align-items: center;
        gap: 5px;
        padding-top: 2px;
        padding-bottom: 2px;
        padding-right: 8px;
        text-align: left;
        cursor: pointer;
        white-space: nowrap;
        transition:
          background 0.12s ease,
          border-color 0.12s ease;
      }

      .tree-row:hover {
        background: var(--hover) !important;
      }

      .tree-row.file-active,
      .tree-row.folder-active {
        background: var(--active) !important;
        border-color: rgba(0, 122, 204, 0.65);
      }

      .tree-arrow {
        width: 14px;
        flex: 0 0 14px;
        color: #c5c5c5;
        text-align: center;
        font-size: 10px;
        line-height: 1;
      }

      .tree-label-wrap {
        min-width: 0;
        flex: 1;
        display: flex;
        align-items: center;
        gap: 6px;
      }

      .tree-label {
        display: inline-block;
        min-width: 0;
        font-size: 13px;
        font-weight: 500;
        color: #d4d4d4;
        overflow: hidden;
        text-overflow: ellipsis;
      }

      .tree-meta {
        display: inline-block;
        margin-left: auto;
        font-size: 10.5px;
        color: #858585;
        opacity: 0;
        transition: opacity 0.12s ease;
      }

      .tree-row:hover .tree-meta,
      .tree-row.file-active .tree-meta,
      .tree-row.folder-active .tree-meta {
        opacity: 1;
      }

      .vscode-icon,
      .project-icon {
        width: 18px;
        height: 18px;
        flex: 0 0 18px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        font-family: Consolas, Menlo, Monaco, monospace;
        font-size: 10px;
        font-weight: 900;
        line-height: 1;
      }

      .project-icon {
        border-radius: 5px;
      }

      .project-icon.html {
        color: var(--html);
        background: rgba(228, 77, 38, 0.12);
      }

      .project-icon.react {
        color: var(--react);
        background: rgba(97, 218, 251, 0.12);
      }

      .project-icon.vue {
        color: var(--vue);
        background: rgba(66, 184, 131, 0.12);
      }

      .icon-folder {
        color: var(--folder);
        font-size: 15px;
      }

      .icon-html {
        color: var(--html);
      }

      .icon-css {
        color: var(--css);
      }

      .icon-js {
        color: var(--js);
      }

      .icon-react {
        color: var(--react);
        font-size: 13px;
      }

      .icon-vue {
        color: var(--vue);
      }

      .icon-json {
        color: var(--json);
      }

      .icon-md {
        color: var(--md);
      }

      .icon-astro {
        color: var(--astro);
      }

      .icon-text {
        color: var(--text-file);
      }

      .editor-body {
        min-height: 0;
        flex: 1;
        display: flex;
        flex-direction: column;
      }

      .editor-info {
        padding: 14px 16px;
        border-bottom: 1px solid var(--border);
        background: #202020;
      }

      .mode-text {
        font-size: 13px;
        color: var(--muted);
        margin: 0 0 14px 0;
        line-height: 1.5;
      }

      label {
        display: block;
        font-size: 12px;
        color: var(--muted);
        margin-bottom: 6px;
      }

      input {
        width: 100%;
        border: 1px solid var(--border);
        border-radius: 10px;
        background: #1e1e1e;
        color: var(--text);
        padding: 10px 12px;
        outline: none;
      }

      input[readonly] {
        background: #1b1b1b;
        color: #bcbcbc;
      }

      .selected-path-grid {
        display: grid;
        grid-template-columns: minmax(0, 1fr) auto;
        gap: 10px;
        align-items: end;
      }

      .editor-badges {
        display: flex;
        gap: 8px;
        align-items: center;
        flex-wrap: wrap;
        padding-bottom: 1px;
      }

      .editor-host-wrap {
        position: relative;
        min-height: 0;
        flex: 1;
        background: #1e1e1e;
      }

      #editorHost {
        position: absolute;
        inset: 0;
      }

      .editor-fallback-textarea {
        width: 100%;
        height: 100%;
        border: none;
        outline: none;
        resize: none;
        padding: 16px;
        background: #1e1e1e !important;
        color: #d4d4d4 !important;
        font-family: Consolas, Menlo, Monaco, monospace;
        font-size: 14px;
        line-height: 1.6;
      }

      .editor-fallback-textarea:disabled {
        opacity: 0.7;
        cursor: not-allowed;
      }

      .editor-empty {
        position: absolute;
        inset: 0;
        z-index: 4;
        display: grid;
        place-items: center;
        padding: 24px;
        pointer-events: none;
        background:
          radial-gradient(circle at top, rgba(14, 99, 156, 0.14), transparent 42%),
          #1e1e1e;
      }

      .editor-empty-card {
        width: min(92%, 440px);
        padding: 26px;
        border: 1px solid var(--border);
        border-radius: 16px;
        background: rgba(37, 37, 38, 0.92);
        box-shadow: var(--shadow);
        text-align: center;
      }

      .editor-empty-card h2 {
        margin: 0 0 10px;
        color: #ffffff;
        font-size: 20px;
      }

      .editor-empty-card p {
        margin: 0;
        color: var(--muted);
        font-size: 13px;
        line-height: 1.65;
      }

      .muted {
        color: var(--muted);
        font-size: 13px;
      }

      .editor-actions {
        min-height: 58px;
        display: flex;
        gap: 10px;
        align-items: center;
        justify-content: space-between;
        flex-wrap: wrap;
        padding: 10px 16px;
        border-top: 1px solid var(--border);
        background: #181818;
      }

      .editor-action-left,
      .editor-action-right {
        display: flex;
        gap: 10px;
        align-items: center;
        flex-wrap: wrap;
      }

      .btn {
        border: none;
        border-radius: 10px;
        background: var(--accent);
        color: white;
        padding: 10px 14px;
        font-weight: 700;
        cursor: pointer;
        transition:
          background 0.15s ease,
          transform 0.15s ease;
      }

      .btn:hover {
        background: var(--accent-2);
      }

      .btn:active {
        transform: translateY(1px);
      }

      .btn:disabled {
        opacity: 0.6;
        cursor: not-allowed;
      }

      .status {
        font-size: 13px;
        color: var(--muted);
      }

      .ok {
        color: var(--success);
      }

      .bad {
        color: var(--danger);
      }

      .kbd {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-width: 22px;
        padding: 2px 6px;
        border: 1px solid var(--border);
        border-bottom-color: #5a5a5a;
        border-radius: 6px;
        background: #202020;
        color: #d4d4d4;
        font-family: Consolas, Menlo, Monaco, monospace;
        font-size: 11px;
        font-weight: 700;
      }

      .preview-body {
        min-height: 0;
        flex: 1;
        padding: 16px;
        display: flex;
        flex-direction: column;
        gap: 10px;
      }

      .preview-frame {
        width: 100%;
        min-height: 0;
        flex: 1;
        border: 1px solid var(--border);
        border-radius: 10px;
        background: white;
      }

      .badge {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        padding: 3px 8px;
        border-radius: 999px;
        background: #0e639c;
        color: white;
        font-size: 12px;
        font-weight: 700;
        white-space: nowrap;
      }

      .language-badge {
        background: rgba(78, 201, 176, 0.12);
        color: var(--success);
        border: 1px solid rgba(78, 201, 176, 0.28);
      }

      .empty-text {
        color: var(--muted);
        font-size: 13px;
      }

      @media (max-width: 1200px) {
        body {
          overflow: auto;
        }

        .app-shell {
          grid-template-columns: 340px minmax(0, 1fr);
          height: auto;
          min-height: calc(100vh - 48px);
        }

        .preview-panel {
          grid-column: 1 / -1;
          border-top: 1px solid var(--border);
        }

        .editor-body {
          min-height: 700px;
        }

        .preview-frame {
          height: 420px;
          flex: 0 0 auto;
        }
      }

      @media (max-width: 760px) {
        .app-shell {
          grid-template-columns: 1fr;
        }

        .panel {
          border-right: none;
          border-bottom: 1px solid var(--border);
        }

        .selected-path-grid {
          grid-template-columns: 1fr;
        }

        .preview-frame {
          height: 360px;
        }
      }
    </style>
  </head>

  <body>
    <div class="topbar">
      <span>Dynamic Page Builder</span>
      <span class="topbar-sub">Multi-framework workspace · Monaco Editor</span>
    </div>

    <div class="app-shell">
      <aside class="panel">
        <div class="panel-head">
          <div class="panel-title">Workspace</div>
        </div>

        <div class="workspace-scroll">
          <div class="section-card">
            <div class="section-head">
              <div class="section-title">Projects</div>

              <div class="toolbar">
                <button id="newProjectBtn" class="icon-btn" type="button">+ Project</button>
                <button id="renameProjectBtn" class="icon-btn" type="button">Rename</button>
                <button id="deleteProjectBtn" class="icon-btn" type="button">Delete</button>
                <button id="refreshProjectsBtn" class="icon-btn" type="button">Refresh</button>
              </div>
            </div>

            <div class="section-body">
              <div id="projectsList" class="project-list">
                <div class="empty-text">Loading projects...</div>
              </div>
            </div>
          </div>

          <div class="section-card">
            <div class="section-head">
              <div class="section-title">Explorer</div>

              <div class="toolbar">
                <button id="newFileBtn" class="icon-btn" type="button">+ File</button>
                <button id="newFolderBtn" class="icon-btn" type="button">+ Folder</button>
                <button id="renameBtn" class="icon-btn" type="button">Rename</button>
                <button id="deleteBtn" class="icon-btn" type="button">Delete</button>
                <button id="refreshBtn" class="icon-btn" type="button">Refresh</button>
              </div>
            </div>

            <div class="section-body">
              <div class="explorer-context">
                <strong>Selected Project</strong>
                <div id="selectedProjectText" class="muted">No project selected</div>
              </div>

              <div class="explorer-context">
                <strong>Selected Folder</strong>
                <div id="selectedFolderText" class="muted">Root</div>
              </div>

              <div id="nodesTree" class="tree-root">
                <div class="empty-text">Loading files...</div>
              </div>
            </div>
          </div>
        </div>
      </aside>

      <section class="panel">
        <div class="panel-head">
          <div class="panel-title">Editor</div>
        </div>

        <div class="editor-body">
          <div class="editor-info">
            <p id="editorMode" class="mode-text">
              Select a project and then choose a file to edit.
            </p>

            <div class="selected-path-grid">
              <div>
                <label>Selected Path</label>
                <input id="selectedPathInput" readonly />
              </div>

              <div class="editor-badges">
                <span id="fileTypeBadge" class="badge" style="display:none;"></span>
                <span id="languageBadge" class="badge language-badge" style="display:none;"></span>
              </div>
            </div>

            <div id="publishedUrlRow" class="muted" style="margin-top:10px; display:none;">
              Published URL:
              <a
                id="publishedUrlLink"
                href="#"
                target="_blank"
                style="color:#93c5fd; text-decoration:none;"
              ></a>
            </div>
          </div>

          <div class="editor-host-wrap">
            <div id="editorHost"></div>

            <div id="editorEmpty" class="editor-empty">
              <div class="editor-empty-card">
                <h2>Open a file to start editing</h2>
                <p>
                  Monaco Editor is ready. Open HTML, CSS, JavaScript, JSX, TypeScript,
                  Vue, JSON, or Markdown files to get syntax highlighting and a
                  VS Code-like editing experience.
                </p>
              </div>
            </div>
          </div>

          <div class="editor-actions">
            <div class="editor-action-left">
              <button id="saveBtn" class="btn" type="button" disabled>Save File</button>
              <span class="status">
                Shortcut:
                <span class="kbd">Ctrl</span>
                +
                <span class="kbd">S</span>
              </span>
            </div>

            <div class="editor-action-right">
              <div id="status" class="status"></div>
            </div>
          </div>
        </div>
      </section>

      <section class="panel preview-panel">
        <div class="panel-head">
          <div class="panel-title">Preview</div>
        </div>

        <div class="preview-body">
          <iframe
            id="previewFrame"
            class="preview-frame"
            title="Live preview"
            sandbox="allow-scripts allow-same-origin"
          ></iframe>
        </div>
