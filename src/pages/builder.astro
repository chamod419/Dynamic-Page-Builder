---

---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Dynamic Page Builder</title>
    <style>
      body { font-family: system-ui, Arial; background:#f8fafc; margin:0; }
      .wrap { max-width: 1200px; margin: 40px auto; padding: 0 16px; }
      .card { background:#fff; border:1px solid #e2e8f0; border-radius:12px; padding:16px; }
      .grid {
        display:grid;
        grid-template-columns: 1fr 1fr;
        gap:16px;
        align-items:start;
      }
      label { display:block; font-size:12px; color:#64748b; margin-bottom:6px; }
      input, textarea {
        width:100%;
        border:1px solid #e2e8f0;
        border-radius:10px;
        padding:10px 12px;
        font-size:14px;
        outline:none;
        box-sizing:border-box;
      }
      input[readonly] {
        background:#f1f5f9;
        color:#475569;
        cursor:not-allowed;
      }
      textarea {
        min-height: 420px;
        font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
        resize: vertical;
      }
      .btn {
        background:#2563eb;
        color:white;
        border:none;
        border-radius:10px;
        padding:10px 14px;
        font-weight:600;
        cursor:pointer;
      }
      .btn:disabled { opacity:.6; cursor:not-allowed; }
      .btn-secondary {
        background:#e2e8f0;
        color:#0f172a;
      }
      .muted { color:#64748b; font-size:13px; }
      .status { margin-top:12px; font-size:14px; }
      .ok { color:#16a34a; }
      .bad { color:#dc2626; }
      a { color:#2563eb; }
      .preview-card {
        border:1px solid #e2e8f0;
        border-radius:12px;
        overflow:hidden;
        background:#fff;
      }
      .preview-head {
        padding:12px 14px;
        border-bottom:1px solid #e2e8f0;
        background:#f8fafc;
      }
      .preview-frame {
        width:100%;
        height:520px;
        border:0;
        display:block;
        background:white;
      }
      .section-title {
        margin:0 0 6px 0;
        font-size:14px;
        font-weight:700;
      }
      .editor-top {
        display:flex;
        align-items:center;
        justify-content:space-between;
        gap:12px;
        flex-wrap:wrap;
        margin-bottom:10px;
      }
      .pages-list {
        display:flex;
        flex-direction:column;
        gap:12px;
        margin-top:12px;
      }
      .page-item {
        border:1px solid #e2e8f0;
        border-radius:12px;
        padding:14px;
        display:flex;
        justify-content:space-between;
        align-items:flex-start;
        gap:12px;
        flex-wrap:wrap;
      }
      .page-actions {
        display:flex;
        gap:8px;
        flex-wrap:wrap;
      }
      .small-btn {
        border:none;
        border-radius:8px;
        padding:8px 12px;
        font-size:13px;
        cursor:pointer;
        font-weight:600;
      }
      .edit-btn {
        background:#2563eb;
        color:white;
      }
      .open-btn {
        background:#e2e8f0;
        color:#0f172a;
        text-decoration:none;
        display:inline-flex;
        align-items:center;
      }
      .pill {
        display:inline-block;
        font-size:12px;
        padding:4px 8px;
        border-radius:999px;
        background:#dbeafe;
        color:#1d4ed8;
        font-weight:600;
      }

      @media (max-width: 900px) {
        .grid {
          grid-template-columns: 1fr;
        }
        .preview-frame {
          height:420px;
        }
      }
    </style>
  </head>

  <body>
    <div class="wrap">
      <h1>Dynamic Page Builder (MVP)</h1>

      <div class="card">
        <div class="grid">
          <!-- Left side: editor -->
          <div>
            <div class="editor-top">
              <div>
                <p class="section-title">Page Editor</p>
                <p class="muted" id="editorMode">Create a new page</p>
              </div>

              <button class="btn btn-secondary" id="newPageBtn" type="button">
                Create New Page
              </button>
            </div>

            <div>
              <label>Page Slug (URL)</label>
              <input id="slug" placeholder="e.g. about-us" />
              <p class="muted">This will create: <b id="pathPreview">/p/&lt;slug&gt;</b></p>
            </div>

            <div style="margin-top: 12px;">
              <label>HTML Content</label>
              <textarea id="content"></textarea>
            </div>

            <div style="margin-top: 12px; display:flex; gap:10px; align-items:center;">
              <button class="btn" id="saveBtn" type="button">Save Page</button>
            </div>

            <div class="status" id="status"></div>
          </div>

          <!-- Right side: live preview -->
          <div>
            <p class="section-title">Live Preview</p>

            <div class="preview-card">
              <div class="preview-head">
                <div class="muted">Preview updates while typing</div>
              </div>

              <iframe
                id="previewFrame"
                class="preview-frame"
                title="Live preview"
                sandbox=""
              ></iframe>
            </div>
          </div>
        </div>
      </div>

      <div class="card" style="margin-top:16px;">
        <p class="section-title">Saved Pages</p>
        <p class="muted">Click Edit to load a saved page into the editor.</p>

        <div id="pagesList" class="pages-list">
          <div class="muted">Loading pages...</div>
        </div>
      </div>
    </div>

    <script type="module">
      const slugEl = /** @type {HTMLInputElement|null} */ (document.getElementById("slug"));
      const contentEl = /** @type {HTMLTextAreaElement|null} */ (document.getElementById("content"));
      const saveBtn = /** @type {HTMLButtonElement|null} */ (document.getElementById("saveBtn"));
      const statusEl = /** @type {HTMLDivElement|null} */ (document.getElementById("status"));
      const previewFrame = /** @type {HTMLIFrameElement|null} */ (document.getElementById("previewFrame"));
      const pathPreviewEl = /** @type {HTMLSpanElement|null} */ (document.getElementById("pathPreview"));
      const pagesListEl = /** @type {HTMLDivElement|null} */ (document.getElementById("pagesList"));
      const editorModeEl = /** @type {HTMLParagraphElement|null} */ (document.getElementById("editorMode"));
      const newPageBtn = /** @type {HTMLButtonElement|null} */ (document.getElementById("newPageBtn"));

      const defaultHtml =
`<h2>Hello from dynamic page!</h2>
<p>This page was created from the browser.</p>`;

      /** @type {Array<{slug:string, html:string, createdAt?:string, updatedAt?:string}>} */
      let cachedPages = [];

      function sanitizeSlug(s) {
        return (s || "")
          .trim()
          .toLowerCase()
          .replace(/[^a-z0-9-]/g, "-")
          .replace(/-+/g, "-")
          .replace(/^-|-$/g, "");
      }

      function escapeHtml(value) {
        return String(value || "")
          .replace(/&/g, "&amp;")
          .replace(/</g, "&lt;")
          .replace(/>/g, "&gt;")
          .replace(/"/g, "&quot;")
          .replace(/'/g, "&#39;");
      }

      function formatDate(value) {
        if (!value) return "-";
        try {
          return new Date(value).toLocaleString();
        } catch {
          return value;
        }
      }

      function buildPreviewDocument(html, slug) {
        const pageTitle = slug ? `/p/${slug}` : "Live Preview";

        return `
<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>${pageTitle}</title>
    <style>
      body {
        font-family: system-ui, Arial, sans-serif;
        margin: 0;
        background: #ffffff;
        color: #0f172a;
      }
      .page-wrap {
        max-width: 980px;
        margin: 0 auto;
        padding: 24px 16px;
      }
      .preview-banner {
        font-size: 12px;
        color: #64748b;
        margin-bottom: 16px;
        padding-bottom: 12px;
        border-bottom: 1px solid #e2e8f0;
      }
      .empty {
        color: #64748b;
        font-size: 14px;
        padding: 24px;
        border: 1px dashed #cbd5e1;
        border-radius: 12px;
        background: #f8fafc;
      }
    </style>
  </head>
  <body>
    <div class="page-wrap">
      <div class="preview-banner">${pageTitle}</div>
      ${
        html.trim()
          ? html
          : `<div class="empty">Start typing HTML on the left side to see a live preview.</div>`
      }
    </div>
  </body>
</html>`;
      }

      function renderPreview() {
        if (!slugEl || !contentEl || !previewFrame || !pathPreviewEl) return;

        const slug = sanitizeSlug(slugEl.value);
        const html = contentEl.value;

        pathPreviewEl.textContent = slug ? `/p/${slug}` : "/p/<slug>";
        previewFrame.srcdoc = buildPreviewDocument(html, slug);
      }

      function resetEditor() {
        if (!slugEl || !contentEl || !editorModeEl || !saveBtn || !statusEl) return;

        slugEl.readOnly = false;
        slugEl.value = "";
        contentEl.value = defaultHtml;
        editorModeEl.textContent = "Create a new page";
        saveBtn.textContent = "Save Page";
        statusEl.textContent = "";
        renderPreview();
      }

      function startEdit(page) {
        if (!slugEl || !contentEl || !editorModeEl || !saveBtn || !statusEl) return;

        slugEl.value = page.slug;
        slugEl.readOnly = true;
        contentEl.value = page.html || "";
        editorModeEl.innerHTML = `Editing page: <span class="pill">${escapeHtml(page.slug)}</span>`;
        saveBtn.textContent = "Update Page";
        statusEl.textContent = "";
        renderPreview();
      }

      function renderPagesList() {
        if (!pagesListEl) return;

        if (!cachedPages.length) {
          pagesListEl.innerHTML = '<div class="muted">No saved pages yet.</div>';
          return;
        }

        pagesListEl.innerHTML = cachedPages.map((page) => `
          <div class="page-item">
            <div>
              <div style="font-weight:700; font-size:15px;">/p/${escapeHtml(page.slug)}</div>
              <div class="muted" style="margin-top:6px;">
                Updated: ${escapeHtml(formatDate(page.updatedAt || page.createdAt))}
              </div>
            </div>

            <div class="page-actions">
              <a class="small-btn open-btn" href="/p/${encodeURIComponent(page.slug)}" target="_blank">Open</a>
              <button
                class="small-btn edit-btn"
                type="button"
                data-edit-slug="${escapeHtml(page.slug)}"
              >
                Edit
              </button>
            </div>
          </div>
        `).join("");
      }

      async function loadPages() {
        if (!pagesListEl) return;

        pagesListEl.innerHTML = '<div class="muted">Loading pages...</div>';

        try {
          const res = await fetch("/api/pages/list");
          const text = await res.text();

          let data;
          try {
            data = JSON.parse(text);
          } catch {
            throw new Error(`Server returned non-JSON (status ${res.status}): ${text}`);
          }

          if (!res.ok) throw new Error(data?.error || "Failed to load pages");

          cachedPages = Array.isArray(data?.pages) ? data.pages : [];
          renderPagesList();
        } catch (err) {
          pagesListEl.innerHTML = `<div class="bad">${err?.message || err}</div>`;
        }
      }

      if (
        !slugEl ||
        !contentEl ||
        !saveBtn ||
        !statusEl ||
        !previewFrame ||
        !pathPreviewEl ||
        !pagesListEl ||
        !editorModeEl ||
        !newPageBtn
      ) {
        console.error("Builder elements not found");
      } else {
        contentEl.value = defaultHtml;

        renderPreview();
        loadPages();

        slugEl.addEventListener("input", () => {
          renderPreview();
        });

        contentEl.addEventListener("input", () => {
          renderPreview();
        });

        newPageBtn.addEventListener("click", () => {
          resetEditor();
        });

        pagesListEl.addEventListener("click", (event) => {
          const target = event.target;
          if (!(target instanceof HTMLElement)) return;

          const editBtn = target.closest("[data-edit-slug]");
          if (!editBtn) return;

          const slug = editBtn.getAttribute("data-edit-slug");
          const page = cachedPages.find((item) => item.slug === slug);

          if (page) {
            startEdit(page);
          }
        });

        saveBtn.addEventListener("click", async () => {
          const slug = sanitizeSlug(slugEl.value);
          const html = contentEl.value;

          statusEl.textContent = "";

          if (!slug) {
            statusEl.innerHTML = '<span class="bad">Input a valid slug</span>';
            return;
          }

          if (!html.trim()) {
            statusEl.innerHTML = '<span class="bad">Input valid HTML content</span>';
            return;
          }

          saveBtn.disabled = true;
          const oldText = saveBtn.textContent;
          saveBtn.textContent = "Saving...";

          try {
            const res = await fetch("/api/pages/save", {
              method: "POST",
              headers: { "Content-Type": "application/json" },
              body: JSON.stringify({ slug, html }),
            });

            const text = await res.text();
            let data;

            try {
              data = JSON.parse(text);
            } catch {
              throw new Error(`Server returned non-JSON (status ${res.status}): ${text}`);
            }

            if (!res.ok) throw new Error(data?.error || "Save failed");

            statusEl.innerHTML =
              `<span class="ok">Saved!</span> Open: <a href="${data.url}" target="_blank">${data.url}</a>`;

            await loadPages();
          } catch (err) {
            statusEl.innerHTML = `<span class="bad">${err?.message || err}</span>`;
          } finally {
            saveBtn.disabled = false;
            saveBtn.textContent = oldText;
          }
        });
      }
    </script>
  </body>
</html>