---
export const prerender = false;

import fs from "fs/promises";
import path from "path";

const slug = Astro.params.slug || "";
const dataPath = path.join(process.cwd(), "data", "pages.json");

let pages: any[] = [];
try {
  const raw = await fs.readFile(dataPath, "utf-8");
  pages = JSON.parse(raw);
} catch {
  pages = [];
}

const page = pages.find((p) => p.slug === slug);
if (!page) Astro.response.status = 404;
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{page ? page.slug : "Page Not Found"}</title>
    <style>
      body { font-family: system-ui, Arial; background:#f8fafc; margin:0; }
      .wrap { max-width: 980px; margin: 40px auto; padding: 0 16px; }
      .card { background:#fff; border:1px solid #e2e8f0; border-radius:12px; padding:16px; }
      a { color:#2563eb; }
      .muted { color:#64748b; }
    </style>
  </head>
  <body>
    <div class="wrap">
      {page ? (
        <div class="card">
          {/* <h1>/p/{page.slug}</h1>
          <p class="muted">Rendered from saved JSON content.</p> */}
          <hr />
          <div set:html={page.html}></div>
        </div>
      ) : (
        <div class="card">
          <h1>404 - Page not found</h1>
          <p class="muted">No saved page found for: <b>{slug}</b></p>
          <p>Go to <a href="/builder">/builder</a> and create it.</p>
        </div>
      )}
    </div>
  </body>
</html>